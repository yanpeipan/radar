<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>Feedship Grouped Feeds</title>
    <dateCreated>Mon, 01 Jan 2024 12:00:00 GMT</dateCreated>
  </head>
  <body>
    <!-- Nested subgroups: Tech > Programming -->
    <outline text="Tech" title="Tech">
      <outline text="Programming" title="Programming">
        <outline text="Hacker News" title="Hacker News" type="rss" xmlUrl="https://news.ycombinator.com/rss"/>
        <outline text="Lobsters" title="Lobsters" type="rss" xmlUrl="https://lobste.rs/rss"/>
      </outline>
      <outline text="Tech News" title="Tech News">
        <outline text="The Verge" title="The Verge" type="rss" xmlUrl="https://www.theverge.com/rss/index.xml"/>
      </outline>
    </outline>
    <!-- Mixed: category attribute + nested outline -->
    <outline text="News" title="News">
      <outline text="BBC News" title="BBC News" type="rss" xmlUrl="http://feeds.bbci.co.uk/news/rss.xml"/>
      <outline text="Reuters" title="Reuters" type="rss" xmlUrl="https://feeds.reuters.com/reuters/topNews" category="News"/>
    </outline>
    <!-- Ungrouped feeds with different types -->
    <outline text="Example Blog" title="Example Blog" type="rss" xmlUrl="https://example.com/feed.xml"/>
    <outline text="Example Atom" type="atom" xmlUrl="https://example.com/atom.xml"/>
    <outline text="No Type Feed" xmlUrl="https://example.org/no-type.xml"/>
    <!-- Standalone feed with only text and xmlUrl -->
    <outline text="Minimal Feed" xmlUrl="https://minimal.example/feed.xml"/>
  </body>
</opml>
